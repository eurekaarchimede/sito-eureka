</script>

<script>
// ===== entra sempre dall'alto (no scroll restoration del browser) =====
if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
// se la url ha un hash residuo da un giro precedente, lo puliamo
if (window.location.hash) {
  history.replaceState(null, '', window.location.pathname + window.location.search);
}
window.scrollTo(0, 0);
window.addEventListener('load', () => window.scrollTo(0, 0));

// ===== year =====
document.getElementById('year').textContent = new Date().getFullYear();

// ===== custom cursor =====
const cursor = document.getElementById('cursor');
let mx = 0, my = 0, cx = 0, cy = 0;

window.addEventListener('mousemove', (e) => {
  mx = e.clientX; my = e.clientY;
});

function cursorLoop() {
  cx += (mx - cx) * 0.18;
  cy += (my - cy) * 0.18;
  cursor.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
  requestAnimationFrame(cursorLoop);
}
cursorLoop();

document.querySelectorAll('a, button, [data-hover]').forEach(el => {
  el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
  el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
});

// ===== reveal on scroll =====
const reveals = document.querySelectorAll('.reveal');

if ('IntersectionObserver' in window) {
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  reveals.forEach(el => io.observe(el));

  // safety net: dopo 4s se qualcosa è ancora nascosto, lo mostriamo lo stesso
  setTimeout(() => {
    document.querySelectorAll('.reveal:not(.in)').forEach(el => el.classList.add('in'));
  }, 4000);
} else {
  // niente IO disponibile: mostra tutto subito
  reveals.forEach(el => el.classList.add('in'));
}
</script>

<script type="module">
import * as THREE from 'three';
import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';
import { RectAreaLightUniformsLib } from 'three/addons/lights/RectAreaLightUniformsLib.js';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';
RectAreaLightUniformsLib.init();

const canvas = document.getElementById('bulb-canvas');
const stage = canvas.parentElement;

// ===== renderer =====
const renderer = new THREE.WebGLRenderer({
  canvas,
  antialias: true,
  alpha: true,
  powerPreference: 'high-performance'
});
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.outputColorSpace = THREE.SRGBColorSpace;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.0;
renderer.setClearColor(0x000000, 0);     // canvas davvero trasparente → niente quadrato
if ('transmissionResolutionScale' in renderer) renderer.transmissionResolutionScale = 0.6;

// ===== scene + camera =====
const scene = new THREE.Scene();
// niente background: la canvas è trasparente e lascia vedere starfield + shader hero
scene.background = null;
const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 1000);
camera.position.set(0, 0, 380);

// ===== environment (riflessi reali sul vetro lucido) =====
const pmrem = new THREE.PMREMGenerator(renderer);
pmrem.compileEquirectangularShader();
// blur più alto = riflessi morbidi, non bianchi e netti
const envTex = pmrem.fromScene(new RoomEnvironment(), 0.5).texture;
scene.environment = envTex;

// ===== bulb group =====
const bulb = new THREE.Group();
scene.add(bulb);

// ----- profilo del vetro (a19, in mm * scala) -----
const glassProfile = [
  [0.5, 70],
  [12,  69],
  [24,  66],
  [34,  60],
  [42,  52],
  [47,  42],
  [50,  30],
  [51,  18],
  [50,  6],
  [47, -6],
  [42, -18],
  [34, -28],
  [24, -36],
  [17, -42],
  [15, -48]
].map(p => new THREE.Vector2(p[0], p[1]));

const glassGeo = new THREE.LatheGeometry(glassProfile, 192);
glassGeo.computeVertexNormals();
const glassMat = new THREE.MeshPhysicalMaterial({
  color: 0xffffff,
  transmission: 1.0,
  roughness: 0.0,             // perfettamente liscio
  metalness: 0,
  ior: 1.5,
  thickness: 0.5,
  attenuationColor: new THREE.Color(0xffffff),
  attenuationDistance: Infinity,
  clearcoat: 0,
  iridescence: 0,
  envMapIntensity: 0.0,       // niente env diffuso → vetro non più "lattiginoso"
  specularIntensity: 1,
  specularColor: new THREE.Color(0xffffff),
  transparent: true,
  opacity: 1,
  side: THREE.FrontSide
});
const glass = new THREE.Mesh(glassGeo, glassMat);
bulb.add(glass);

// ----- "press" del vetro interno (base piatta dei fili) -----
const pressGeo = new THREE.CylinderGeometry(7, 9, 18, 24);
const pressMat = new THREE.MeshPhysicalMaterial({
  color: 0xffffff,
  transmission: 0.85,
  roughness: 0.15,
  ior: 1.5,
  thickness: 2,
  envMapIntensity: 1.0,
  transparent: true
});
const press = new THREE.Mesh(pressGeo, pressMat);
press.position.y = -32;
bulb.add(press);

// ----- stelo del vuoto (tubo centrale dietro al filamento) -----
const stemGeo = new THREE.CylinderGeometry(1.6, 1.6, 30, 16);
const stemMat = new THREE.MeshPhysicalMaterial({
  color: 0xffffff,
  transmission: 0.7,
  roughness: 0.18,
  thickness: 1.5,
  ior: 1.5,
  envMapIntensity: 1.0,
  transparent: true
});
const stem = new THREE.Mesh(stemGeo, stemMat);
stem.position.y = -8;
bulb.add(stem);

// ----- supporti del filamento (fili di nichel) -----
const wireMat = new THREE.MeshStandardMaterial({
  color: 0x9a8550, metalness: 0.85, roughness: 0.3, envMapIntensity: 1.4
});
function makeWire(x) {
  const g = new THREE.CylinderGeometry(0.45, 0.45, 28, 12);
  const m = new THREE.Mesh(g, wireMat);
  m.position.set(x, 4, 0);
  return m;
}
bulb.add(makeWire(-9));
bulb.add(makeWire(9));

// ----- FILAMENTO COILED COIL (curva elicoidale orizzontale) -----
const filPoints = [];
const filLength = 18;        // lunghezza orizzontale
const filRadius = 1.0;       // raggio della spirale
const filTurns  = 14;        // n° di spire
for (let i = 0; i <= 220; i++) {
  const t = i / 220;
  const x = -filLength + t * filLength * 2;
  const angle = t * Math.PI * 2 * filTurns;
  const y = Math.sin(angle) * filRadius;
  const z = Math.cos(angle) * filRadius;
  filPoints.push(new THREE.Vector3(x, y, z));
}
const filCurve = new THREE.CatmullRomCurve3(filPoints);
const filGeo   = new THREE.TubeGeometry(filCurve, 600, 0.11, 6, false);  // più sottile
const filMat   = new THREE.MeshStandardMaterial({
  color: 0x0a0805,
  emissive: 0x000000,
  emissiveIntensity: 0,
  metalness: 0.5,
  roughness: 0.5,
  envMapIntensity: 0.8
});
const filament = new THREE.Mesh(filGeo, filMat);
filament.position.y = 18;
bulb.add(filament);

// ----- piccoli ganci sui supporti -----
const hookGeo = new THREE.SphereGeometry(0.7, 12, 8);
const hook1 = new THREE.Mesh(hookGeo, wireMat); hook1.position.set(-9, 18, 0); bulb.add(hook1);
const hook2 = new THREE.Mesh(hookGeo, wireMat); hook2.position.set( 9, 18, 0); bulb.add(hook2);

// ----- SCINTILLE: piccoli punti caldi distribuiti lungo la spirale -----
const sparkGroup = new THREE.Group();
sparkGroup.position.y = 18;
bulb.add(sparkGroup);
const sparks = [];
for (let i = 0; i < 22; i++) {
  // colore tra arancio caldo e ambra
  const hue = 0.07 + Math.random() * 0.04;
  const sat = 1.0;
  const lit = 0.55 + Math.random() * 0.2;
  const c = new THREE.Color().setHSL(hue, sat, lit);
  const m = new THREE.MeshBasicMaterial({ color: c, transparent: true, opacity: 0 });
  const s = new THREE.Mesh(new THREE.SphereGeometry(0.32, 10, 8), m);
  // distribuzione lungo l'asse del filamento, con offset radiale random
  const ux = -filLength + Math.random() * filLength * 2;
  const ang = Math.random() * Math.PI * 2;
  const r = filRadius * (0.6 + Math.random() * 0.6);
  s.position.set(ux, Math.sin(ang) * r, Math.cos(ang) * r);
  s.userData.phase = Math.random() * 6.28;
  s.userData.freq  = 8 + Math.random() * 14;     // frequenza di flicker individuale
  s.userData.size  = 0.7 + Math.random() * 1.6;
  sparks.push(s);
  sparkGroup.add(s);
}

// ----- LUCE INTERNA AMBRATA (point light che si accende) -----
const innerLight = new THREE.PointLight(0xffa040, 0, 260, 2);
innerLight.position.set(0, 18, 0);
bulb.add(innerLight);

// ----- attacco E27: lathe in metallo argentato (nichel/alluminio) -----
const baseProfile = [
  [15, -48],
  [17, -50],
  [19, -54],
  [20, -58],
  [20, -82],
  [18, -86],
  [13, -90]
].map(p => new THREE.Vector2(p[0], p[1]));
const baseGeo = new THREE.LatheGeometry(baseProfile, 64);
const baseMetal = new THREE.MeshStandardMaterial({
  color: 0xb8bcc0,
  metalness: 0.95,
  roughness: 0.22,
  envMapIntensity: 1.4
});
const base = new THREE.Mesh(baseGeo, baseMetal);
bulb.add(base);

// ----- filettatura: spirale continua come nel reference -----
const threadPts = [];
{
  const turns = 5;
  const segments = 320;
  const r = 20.5;
  const yStart = -56;
  const yEnd   = -82;
  for (let i = 0; i <= segments; i++) {
    const t = i / segments;
    const angle = t * Math.PI * 2 * turns;
    const y = yStart + (yEnd - yStart) * t;
    threadPts.push(new THREE.Vector3(Math.cos(angle) * r, y, Math.sin(angle) * r));
  }
}
const threadCurve = new THREE.CatmullRomCurve3(threadPts);
const threadGeo = new THREE.TubeGeometry(threadCurve, 800, 1.0, 10, false);
const threadMat = new THREE.MeshStandardMaterial({
  color: 0xacb0b4,
  metalness: 0.95,
  roughness: 0.28,
  envMapIntensity: 1.4
});
const thread = new THREE.Mesh(threadGeo, threadMat);
bulb.add(thread);

// ----- raccordo nero (mastice) -----
const collarGeo = new THREE.CylinderGeometry(15.6, 15, 3, 32);
const collarMat = new THREE.MeshStandardMaterial({
  color: 0x0a0805, roughness: 0.7, metalness: 0.1
});
const collar = new THREE.Mesh(collarGeo, collarMat);
collar.position.y = -49;
bulb.add(collar);

// ----- isolante nero conico -----
const insGeo = new THREE.CylinderGeometry(13, 9, 8, 32);
const insMat = new THREE.MeshStandardMaterial({
  color: 0x080604, roughness: 0.92, metalness: 0.0
});
const insulator = new THREE.Mesh(insGeo, insMat);
insulator.position.y = -90;
bulb.add(insulator);

// ----- contatto centrale (eyelet) in nichel scuro -----
const padGeo = new THREE.SphereGeometry(6, 24, 16, 0, Math.PI * 2, 0, Math.PI/2);
const padMat = new THREE.MeshStandardMaterial({
  color: 0x6a6e72, metalness: 0.92, roughness: 0.32, envMapIntensity: 1.2
});
const pad = new THREE.Mesh(padGeo, padMat);
pad.scale.y = 0.6;
pad.rotation.x = Math.PI;
pad.position.y = -94;
bulb.add(pad);

// ===== luci di scena =====
scene.add(new THREE.AmbientLight(0xffffff, 0.18));
const key = new THREE.DirectionalLight(0xffffff, 0.5);
key.position.set(4, 6, 8);
scene.add(key);
const rim = new THREE.DirectionalLight(0xfff3c0, 0.35);
rim.position.set(-3, -2, -8);
scene.add(rim);

// ===== "finestre" RectAreaLight: riflessi netti sul vetro come nel reference =====
const win1 = new THREE.RectAreaLight(0xffffff, 8, 90, 160);
win1.position.set(70, 30, 110);
win1.lookAt(0, 0, 0);
scene.add(win1);

const win2 = new THREE.RectAreaLight(0xffffff, 5, 70, 130);
win2.position.set(-80, 20, 90);
win2.lookAt(0, 0, 0);
scene.add(win2);

const win3 = new THREE.RectAreaLight(0xffffff, 4, 50, 110);
win3.position.set(0, 80, 100);
win3.lookAt(0, 0, 0);
scene.add(win3);

// ===== post-processing: bloom (rende il filamento davvero incandescente) =====
const composer = new EffectComposer(renderer);
const renderPass = new RenderPass(scene, camera);
const bloomPass = new UnrealBloomPass(
  new THREE.Vector2(1, 1),
  0.85,    // strength
  0.55,    // radius
  0.78     // threshold (solo i pixel sopra questa luminosità contribuiscono al bloom)
);
const outputPass = new OutputPass();
composer.addPass(renderPass);
composer.addPass(bloomPass);
composer.addPass(outputPass);

// ===== resize =====
function resize() {
  const w = stage.clientWidth;
  const h = stage.clientHeight;
  renderer.setSize(w, h, false);
  composer.setSize(w, h);
  composer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
  bloomPass.resolution.set(w, h);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}
new ResizeObserver(resize).observe(stage);
resize();

// ===== animazione realistica =====
//   rotazione lenta di idle + parallasse al cursore + drag con inerzia.
//   filamento segue la curva del corpo nero del tungsteno: 1500K→2000K→2500K→2700K
//   con flicker elettrico realistico (low-freq drift + alta-freq chatter + dip rari).
const IDLE_YAW_SPEED   = 0.35;   // rad/s — drift lento, quasi statico
const IDLE_YAW_WOBBLE  = 0.04;   // rad — wobble sinusoidale
const PARALLAX_AMP_X   = 0.35;   // rad — yaw guidato dal cursore
const PARALLAX_AMP_Y   = 0.22;   // rad — pitch guidato dal cursore
const PARALLAX_LERP    = 4.0;    // velocità di inseguimento del target
const DRAG_SENS        = 0.012;  // rad per pixel
const DRAG_FRICTION    = 4.5;    // decay della velocità angolare al rilascio
const SPARK_START    = 1.5;
const SPARK_PEAK     = 4.5;
const HEAT_START     = 2.0;
const HEAT_FULL      = 9.5;
const SPARK_FADE_END = 9.0;
const STARTUP_STUTTER_END = 4.0;  // sbalzi di accensione dopo HEAT_START

// curva blackbody del tungsteno (kelvin → rgb sRGB approssimato)
//   1500K  #ff5c0c — primo bagliore rosso scuro
//   2000K  #ff7d22 — arancione
//   2500K  #ff9d3f — ambra
//   2700K  #ffb556 — incandescente standard (lampadina reale)
//   3000K  #ffc888 — più caldo se overdriven
const COLOR_COLD = new THREE.Color(0x140d07);     // tungsteno freddo, quasi nero
const COLOR_K1500 = new THREE.Color(0xff5c0c);
const COLOR_K2000 = new THREE.Color(0xff7d22);
const COLOR_K2500 = new THREE.Color(0xff9d3f);
const COLOR_K2700 = new THREE.Color(0xffb556);

let startTime = performance.now() * 0.001;
let lastTime  = startTime;
const haloEl = stage;

function smoothstep(k) { return k * k * (3 - 2 * k); }
function clamp(v, a, b){ return v < a ? a : v > b ? b : v; }
const tmpColor = new THREE.Color();

// ===== INTERAZIONE: parallasse cursore + drag con inerzia =====
const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

let targetYaw   = 0;   // contributo cursore/drag su yaw
let targetPitch = 0;
let curYaw      = 0;   // valori interpolati realmente applicati
let curPitch    = 0;
let dragVelYaw   = 0;  // inerzia post-drag
let dragVelPitch = 0;

let isDragging = false;
let pointerId  = null;
let lastPx = 0, lastPy = 0;
let dragMoved = 0;     // somma deltas — distingue tap da drag
let pointerInside = false;

function onMove(ev){
  const r = stage.getBoundingClientRect();
  const nx = ((ev.clientX - r.left) / r.width)  * 2 - 1;
  const ny = ((ev.clientY - r.top)  / r.height) * 2 - 1;

  if (isDragging){
    const dx = ev.clientX - lastPx;
    const dy = ev.clientY - lastPy;
    targetYaw   += dx * DRAG_SENS;
    targetPitch += dy * DRAG_SENS;
    targetPitch = clamp(targetPitch, -0.6, 0.6);
    dragVelYaw   = dx * DRAG_SENS * 60;   // px/frame → rad/s approx
    dragVelPitch = dy * DRAG_SENS * 60;
    dragMoved += Math.abs(dx) + Math.abs(dy);
    lastPx = ev.clientX;
    lastPy = ev.clientY;
  } else if (pointerInside){
    targetYaw   = nx *  PARALLAX_AMP_X;
    targetPitch = ny *  PARALLAX_AMP_Y;
  }
}
function onDown(ev){
  isDragging = true;
  dragMoved = 0;
  pointerId = ev.pointerId;
  lastPx = ev.clientX; lastPy = ev.clientY;
  stage.classList.add('dragging');
  if (stage.setPointerCapture) stage.setPointerCapture(ev.pointerId);
}
function onUp(){
  if (!isDragging) return;
  isDragging = false;
  const wasTap = dragMoved < 6;     // soglia: sotto 6px è un click, non un drag
  stage.classList.remove('dragging');
  if (pointerId != null && stage.releasePointerCapture){
    try { stage.releasePointerCapture(pointerId); } catch(_){}
  }
  pointerId = null;
  if (wasTap){
    userOverride = true;
    powerOn = !powerOn;
    // piccolo "kick" di flicker realistico al toggle
    flickerKickEndsAt = (performance.now() * 0.001) + 0.6;
  }
}
function onEnter(){ pointerInside = true; }
function onLeave(){
  pointerInside = false;
  // ritorna a target idle (nullo)
  targetYaw = 0; targetPitch = 0;
}

stage.addEventListener('pointermove',  onMove);
stage.addEventListener('pointerdown',  onDown);
stage.addEventListener('pointerup',    onUp);
stage.addEventListener('pointercancel',onUp);
stage.addEventListener('pointerenter', onEnter);
stage.addEventListener('pointerleave', () => { onLeave(); onUp(); });

// ===== UI editoriale: aggiorna kelvin + watt + power state =====
const kelvinEl = document.getElementById('bulb-kelvin');
const wattEl   = document.getElementById('bulb-watt');
const pwrEl    = document.getElementById('bulb-pwr');
const dotEl    = stage.querySelector('.bulb-ui-label .dot.live');

// curva watt percepiti: da 0 a 60W con il riscaldamento
function kelvinFromHeat(h){
  if (h <= 0)   return 0;
  if (h < 0.25) return Math.round(800 + (1500-800) * (h/0.25));
  if (h < 0.55) return Math.round(1500 + (2000-1500) * ((h-0.25)/0.30));
  if (h < 0.80) return Math.round(2000 + (2500-2000) * ((h-0.55)/0.25));
  return Math.round(2500 + (2700-2500) * ((h-0.80)/0.20));
}

// ===== FLICKER realistico (multi-octave + dip rari) =====
//   somma di sinusoidi non commensurabili → segnale pseudo-random
//   fascia ±0.06 in idle, dip occasionali fino a -0.4 nei primi 4s
function flickerSignal(t, heat){
  const slow = Math.sin(t*1.8 + 0.3) * Math.sin(t*0.7 + 1.1);
  const mid  = Math.sin(t*7.3 + 2.1) * 0.55;
  const fast = Math.sin(t*23.1 + 0.4) * 0.35;
  let f = (slow*0.5 + mid + fast) / 2.0;   // ~ -1..1
  // dip casuali nei primi secondi (startup stutter)
  if (t < STARTUP_STUTTER_END){
    const stutter = Math.sin(t*40.0) * Math.sin(t*9.7);
    if (stutter > 0.65) f -= (stutter - 0.65) * 2.4;
  }
  // ampiezza: piccola da spento (no senso), max in transitorio, ridotta a regime
  const amp = heat < 0.05 ? 0.02
            : heat < 0.85 ? (0.06 + 0.18 * (1 - heat))
                          : 0.045;
  return f * amp;
}

// lerp tungsten color attraverso 4 stop (heat 0..1)
function tungstenColor(heat, out) {
  if (heat <= 0)        { out.copy(COLOR_COLD); return; }
  if (heat >= 1)        { out.copy(COLOR_K2700); return; }
  if (heat < 0.25) {
    out.copy(COLOR_COLD).lerp(COLOR_K1500, heat / 0.25);
  } else if (heat < 0.55) {
    out.copy(COLOR_K1500).lerp(COLOR_K2000, (heat - 0.25) / 0.30);
  } else if (heat < 0.80) {
    out.copy(COLOR_K2000).lerp(COLOR_K2500, (heat - 0.55) / 0.25);
  } else {
    out.copy(COLOR_K2500).lerp(COLOR_K2700, (heat - 0.80) / 0.20);
  }
}

// throttle UI DOM writes (kelvin/watt/pwr) a ~10 Hz
let lastUiWrite = 0;
let lastKelvin  = -1, lastWatt = -1, lastPwr = '';
let baseYaw     = 0;     // accumulator del drift idle (yaw assoluto)

// ===== power state (tap per toggle) =====
let powerOn          = true;     // utente vuole accesa
let userOverride     = false;    // dopo il primo tap: ignora la curva di startup
let displayHeat      = 0;        // heat realmente animato (lerp verso target)
let flickerKickEndsAt = 0;       // burst di flicker al toggle

// ===== pausa composer quando il bulb è fuori dal viewport =====
let bulbVisible = true;
const bulbIO = new IntersectionObserver(
  (es) => { bulbVisible = es[0].isIntersecting; },
  { threshold: 0, rootMargin: '120px' }
);
bulbIO.observe(stage);

function tick() {
  const now = performance.now() * 0.001;
  const dt  = Math.min(now - lastTime, 0.05);
  const t   = now - startTime;
  lastTime  = now;

  // pausa rendering quando bulb è fuori dal viewport (risparmia GPU)
  if (!bulbVisible){
    requestAnimationFrame(tick);
    return;
  }

  // ----- rotazione idle + parallasse cursore + inerzia drag -----
  if (!isDragging){
    // drift continua solo quando non si trascina
    baseYaw += IDLE_YAW_SPEED * dt;
    // inerzia post-drag: la velocità rimasta entra nel target e decade con friction
    targetYaw   += dragVelYaw   * dt;
    targetPitch += dragVelPitch * dt;
    const dec = Math.exp(-DRAG_FRICTION * dt);
    dragVelYaw   *= dec;
    dragVelPitch *= dec;
    if (Math.abs(dragVelYaw)   < 0.001) dragVelYaw   = 0;
    if (Math.abs(dragVelPitch) < 0.001) dragVelPitch = 0;
    targetPitch = clamp(targetPitch, -0.6, 0.6);
  }

  // lerp morbido del contributo "cursore/drag"
  const k = 1 - Math.exp(-PARALLAX_LERP * dt);
  curYaw   += (targetYaw   - curYaw)   * k;
  curPitch += (targetPitch - curPitch) * k;

  // micro-wobble idle (pendolo) + leggero swing laterale → niente robot
  const wobble = Math.sin(now * 0.6) * IDLE_YAW_WOBBLE;
  bulb.rotation.y = baseYaw + curYaw;
  bulb.rotation.x = curPitch + wobble;
  bulb.rotation.z = Math.sin(now * 0.4) * 0.012;

  // ----- heat: target dipende dal power state, lerp morbido verso displayHeat -----
  let targetHeat;
  if (userOverride){
    targetHeat = powerOn ? 1 : 0;
  } else {
    // sequenza di accensione automatica al primo caricamento
    if (t < HEAT_START)      targetHeat = 0;
    else if (t < HEAT_FULL)  targetHeat = smoothstep((t - HEAT_START) / (HEAT_FULL - HEAT_START));
    else                     targetHeat = 1;
  }
  // tempi diversi per accensione vs spegnimento (filamento incandescente vero)
  const heatLerp = (targetHeat > displayHeat) ? 2.2 : 6.5;
  displayHeat += (targetHeat - displayHeat) * (1 - Math.exp(-heatLerp * dt));
  const heat = displayHeat;

  // ----- flicker realistico (additivo, può scendere sotto 0 nei dip) -----
  let flicker = reduceMotion ? 0 : flickerSignal(now, heat);
  // burst extra al toggle (interruttore meccanico → contatto instabile per ~0.6s)
  if (now < flickerKickEndsAt){
    const kickAmt = (flickerKickEndsAt - now) / 0.6;
    flicker += Math.sin(now * 38) * 0.25 * kickAmt;
  }
  const heatFx  = clamp(heat + flicker, 0, 1.05);

  // ----- filamento incandescente (blackbody curve + bloom amplifies) -----
  tungstenColor(clamp(heatFx, 0, 1), tmpColor);
  filMat.emissive.copy(tmpColor);
  filMat.emissiveIntensity = Math.pow(clamp(heatFx, 0, 1.05), 1.3) * 18.0;  // alto: il bloom dilata
  // base color sale leggermente per non avere punti neri all'interno del coil
  filMat.color.setRGB(0.05 + heatFx * 0.25, 0.03 + heatFx * 0.18, 0.02 + heatFx * 0.10);

  // ----- luce interna (illumina vetro + supporti dall'interno) -----
  innerLight.color.copy(tmpColor);
  innerLight.intensity = Math.pow(clamp(heatFx, 0, 1.05), 1.5) * 6.5;

  // alone css esterno + flicker → CSS variables (per UI editoriale)
  haloEl.style.setProperty('--ignition', (heatFx * 0.95).toFixed(3));
  haloEl.style.setProperty('--flicker', flicker.toFixed(3));
  haloEl.style.setProperty('--flicker-abs', Math.abs(flicker).toFixed(3));

  // ----- scintille: subtle → intensify → fade dentro il glow -----
  let sparkEnvelope;
  if (t < SPARK_START || t > SPARK_FADE_END) sparkEnvelope = 0;
  else {
    const s = (t - SPARK_START) / (SPARK_FADE_END - SPARK_START);
    const peakNorm = (SPARK_PEAK - SPARK_START) / (SPARK_FADE_END - SPARK_START);
    if (s < peakNorm) sparkEnvelope = smoothstep(s / peakNorm);
    else              sparkEnvelope = 1 - smoothstep((s - peakNorm) / (1 - peakNorm));
  }

  sparks.forEach((s) => {
    const f = 0.5 + 0.5 * Math.sin(now * s.userData.freq + s.userData.phase);
    const lit = Math.pow(f, 2) * sparkEnvelope;
    s.material.opacity = lit;
    s.scale.setScalar(s.userData.size * (0.4 + lit * 1.6));
  });

  // ----- UI editoriale: kelvin + watt + power (throttled) -----
  if (now - lastUiWrite > 0.1){
    lastUiWrite = now;
    const kev = kelvinFromHeat(clamp(heatFx, 0, 1));
    const wat = Math.round(clamp(heatFx, 0, 1) * 60);
    const pwr = heat < 0.04 ? 'OFF' : (heat < 0.92 ? 'WARM' : 'ON');
    if (kev !== lastKelvin && kelvinEl){ kelvinEl.textContent = kev; lastKelvin = kev; }
    if (wat !== lastWatt   && wattEl)  { wattEl.textContent   = wat; lastWatt   = wat; }
    if (pwr !== lastPwr    && pwrEl){
      pwrEl.textContent = pwr;
      pwrEl.classList.toggle('off', pwr === 'OFF');
      lastPwr = pwr;
    }
  }

  composer.render();    // post-processing pass (renderPass + bloom + output)
  requestAnimationFrame(tick);
}
tick();

// =====================================================================
// ===== SHADER ANIMATION (background sezione cta) =====================
// =====================================================================
// fragment shader radial-line da 21st.dev, ricolorato sulla palette
// "notte stellata": blu notte → blu cobalto → giallo cadmio → cream.
const shaderCanvas = document.getElementById('shader-canvas');
if (shaderCanvas) {
  const sRenderer = new THREE.WebGLRenderer({
    canvas: shaderCanvas,
    antialias: true,
    alpha: false
  });
  sRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  sRenderer.outputColorSpace = THREE.SRGBColorSpace;

  const sCamera = new THREE.Camera();
  sCamera.position.z = 1;
  const sScene = new THREE.Scene();

  const sUniforms = {
    time:       { value: 1.0 },
    resolution: { value: new THREE.Vector2() }
  };

  const sVertex = /* glsl */`
    void main() { gl_Position = vec4(position, 1.0); }
  `;

  // palette starry-night come uniform-free constants (più veloce)
  const sFragment = /* glsl */`
    precision highp float;
    uniform vec2  resolution;
    uniform float time;

    void main(void) {
      vec2 uv = (gl_FragCoord.xy * 2.0 - resolution.xy) / min(resolution.x, resolution.y);
      float t = time * 0.05;
      float lineWidth = 0.002;

      // 3 accumulatori sfasati nel tempo (RGB chromatic aberration originale)
      float iR = 0.0, iG = 0.0, iB = 0.0;
      for (int i = 0; i < 5; i++) {
        float fi = float(i);
        iR += lineWidth * fi*fi / abs(fract(t - 0.01 + fi * 0.01) * 5.0 - length(uv) + mod(uv.x + uv.y, 0.2));
        iG += lineWidth * fi*fi / abs(fract(t        + fi * 0.01) * 5.0 - length(uv) + mod(uv.x + uv.y, 0.2));
        iB += lineWidth * fi*fi / abs(fract(t + 0.01 + fi * 0.01) * 5.0 - length(uv) + mod(uv.x + uv.y, 0.2));
      }
      float intensity = (iR + iG + iB) / 3.0;

      // ramp 4-stop sulla palette notte stellata
      vec3 cBg    = vec3(0.039, 0.086, 0.196);   // #0a1632 blu notte
      vec3 cMid   = vec3(0.141, 0.247, 0.478);   // #243f7a swirl cobalto
      vec3 cGold  = vec3(0.961, 0.804, 0.278);   // #f5cd47 oro cadmio
      vec3 cCream = vec3(0.969, 0.929, 0.836);   // #f7eed5 highlight

      vec3 col = mix(cBg,   cMid,   smoothstep(0.05, 0.55, intensity));
      col      = mix(col,   cGold,  smoothstep(0.55, 1.40, intensity));
      col      = mix(col,   cCream, smoothstep(1.60, 3.20, intensity));

      // micro-shift cromatico per vibrazione
      col.r += (iR - intensity) * 0.18;
      col.b += (iB - intensity) * 0.18;

      gl_FragColor = vec4(col, 1.0);
    }
  `;

  const sMat = new THREE.ShaderMaterial({
    uniforms: sUniforms,
    vertexShader: sVertex,
    fragmentShader: sFragment
  });
  sScene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), sMat));

  function shaderResize() {
    const w = shaderCanvas.clientWidth;
    const h = shaderCanvas.clientHeight;
    sRenderer.setSize(w, h, false);
    sUniforms.resolution.value.set(shaderCanvas.width, shaderCanvas.height);
  }
  new ResizeObserver(shaderResize).observe(shaderCanvas);
  shaderResize();

  // pausa automatica fuori viewport per non sprecare gpu
  let shaderActive = false;
  let shaderRAF = 0;
  function shaderTick() {
    sUniforms.time.value += 0.05;
    sRenderer.render(sScene, sCamera);
    shaderRAF = requestAnimationFrame(shaderTick);
  }
  const shaderObs = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting && !shaderActive) {
        shaderActive = true;
        shaderTick();
      } else if (!e.isIntersecting && shaderActive) {
        shaderActive = false;
        if (shaderRAF) cancelAnimationFrame(shaderRAF);
      }
    }
  }, { threshold: 0.05 });
  shaderObs.observe(shaderCanvas);

  // rispetta prefers-reduced-motion: render statico singolo
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    shaderObs.disconnect();
    if (shaderRAF) cancelAnimationFrame(shaderRAF);
    sRenderer.render(sScene, sCamera);
  }
}
</script>

<script>
// =====================================================================
// ===== HERO SHADER — notte stellata animata (fbm + clouds + glints) ==
// =====================================================================
// adattato da @atzedent (registry: ravikatiyar162/animated-shader-hero)
// ricolorato sulla palette starry-night: blu notte → cobalto + glints
// oro cadmio/cream. webgl2 puro, niente three.js.
(() => {
  const canvas = document.getElementById('hero-shader-canvas');
  if (!canvas) return;
  const gl = canvas.getContext('webgl2', { antialias: false, alpha: true, premultipliedAlpha: false });
  if (!gl) return;

  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const VS = `#version 300 es
precision highp float;
in vec4 position;
void main(){ gl_Position = position; }`;

  const FS = `#version 300 es
precision highp float;
out vec4 O;
uniform vec2  resolution;
uniform float time;
#define FC gl_FragCoord.xy
#define T  time
#define R  resolution
#define MN min(R.x, R.y)

float rnd(vec2 p){
  p = fract(p * vec2(12.9898, 78.233));
  p += dot(p, p + 34.56);
  return fract(p.x * p.y);
}
float noise(in vec2 p){
  vec2 i = floor(p), f = fract(p), u = f*f*(3.0 - 2.0*f);
  float a = rnd(i),
        b = rnd(i + vec2(1,0)),
        c = rnd(i + vec2(0,1)),
        d = rnd(i + 1.0);
  return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}
float fbm(vec2 p){
  float t = 0.0, a = 1.0;
  mat2 m = mat2(1.0, -0.5, 0.2, 1.2);
  for (int i = 0; i < 6; i++){           // +1 ottava → dettaglio più fine
    t += a * noise(p);
    p *= 2.0 * m;
    a *= 0.55;                           // amplitude decay più morbido → swirl più definiti
  }
  return t;
}
float clouds(vec2 p){
  float d = 1.0, t = 0.0;
  for (float i = 0.0; i < 4.0; i++){     // 3 → 4 octave
    float a = d * fbm(i*10.0 + p.x*0.2 + 0.2*(1.0 + i)*p.y + d + i*i + p);
    t = mix(t, d, a);
    d = a;
    p *= 2.0 / (i + 1.0);
  }
  // contrast curve → nubi più nitide, vortici più definiti
  t = clamp((t - 0.18) * 1.55, 0.0, 1.0);
  t = smoothstep(0.0, 1.0, t);
  return t;
}

void main(void){
  vec2 uv = (FC - 0.5*R) / MN;
  vec2 st = uv * vec2(2.0, 1.0);

  // base: blu notte profondo — stesso colore di --bg (#0a1632)
  vec3 col = vec3(0.039, 0.086, 0.196);

  // strato di "nuvole" (swirl van gogh) modulato lentamente
  float bg = clouds(vec2(st.x + T*0.18, -st.y));

  uv *= 1.0 - 0.25 * (sin(T*0.18) * 0.5 + 0.5);

  for (float i = 1.0; i < 18.0; i++){
    uv += 0.10 * cos(i*vec2(0.10 + 0.01*i, 0.8) + i*i + T*0.30 + 0.10*uv.x);
    vec2 p = uv;
    float d = length(p);

    // glints: stelle in oro cadmio ↔ cream (variano con l'indice)
    vec3 starGold  = vec3(0.961, 0.804, 0.278);   // #f5cd47
    vec3 starCream = vec3(0.969, 0.929, 0.836);   // #f7eed5
    vec3 glint = mix(starGold, starCream, 0.5 + 0.5*sin(i*1.7));
    col += 0.0019 / d * glint;

    // contributo strutturale (riga di luce sottile)
    float b = noise(i + p + bg*1.731);
    col += 0.0024 * b / length(max(p, vec2(b*p.x*0.02, p.y))) * starGold;

    // tint verso swirl cobalto in funzione della distanza/clouds
    vec3 swirl = mix(
      vec3(0.039, 0.086, 0.196),  // night
      vec3(0.141, 0.247, 0.478),  // #243f7a swirl cobalto
      bg
    );
    col = mix(col, swirl, d * 0.8);
  }

  O = vec4(col, 1.0);
}`;

  function compile(type, src){
    const sh = gl.createShader(type);
    gl.shaderSource(sh, src);
    gl.compileShader(sh);
    if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)){
      console.warn('hero-shader compile:', gl.getShaderInfoLog(sh));
      gl.deleteShader(sh);
      return null;
    }
    return sh;
  }

  const vs = compile(gl.VERTEX_SHADER, VS);
  const fs = compile(gl.FRAGMENT_SHADER, FS);
  if (!vs || !fs) return;

  const prog = gl.createProgram();
  gl.attachShader(prog, vs);
  gl.attachShader(prog, fs);
  gl.linkProgram(prog);
  if (!gl.getProgramParameter(prog, gl.LINK_STATUS)){
    console.warn('hero-shader link:', gl.getProgramInfoLog(prog));
    return;
  }

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,1,-1,-1,1,1,1,-1]), gl.STATIC_DRAW);
  const posLoc = gl.getAttribLocation(prog, 'position');
  gl.enableVertexAttribArray(posLoc);
  gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

  const uRes  = gl.getUniformLocation(prog, 'resolution');
  const uTime = gl.getUniformLocation(prog, 'time');

  // dpr cap a 1.5 → costa molto meno e sul retina è invisibile la differenza
  function resize(){
    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    const w = canvas.clientWidth, h = canvas.clientHeight;
    canvas.width  = Math.max(1, Math.floor(w * dpr));
    canvas.height = Math.max(1, Math.floor(h * dpr));
    gl.viewport(0, 0, canvas.width, canvas.height);
  }
  new ResizeObserver(resize).observe(canvas);
  resize();

  // pause shader quando la sezione esce dal viewport (risparmia GPU sul resto del sito)
  let visible = true;
  const heroSection = canvas.closest('.hero');
  if (heroSection){
    const io = new IntersectionObserver(es => { visible = es[0].isIntersecting; }, { threshold: 0 });
    io.observe(heroSection);
  }

  let raf;
  function frame(now){
    if (visible){
      gl.useProgram(prog);
      gl.uniform2f(uRes, canvas.width, canvas.height);
      gl.uniform1f(uTime, reduceMotion ? 0.0 : now * 0.001);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    }
    if (reduceMotion) return; // un frame solo, niente loop
    raf = requestAnimationFrame(frame);
  }
  frame(0);
})();
</script>

<script>
// =====================================================================
// ===== STARFIELD GLOBALE + STELLE CADENTI ============================
// =====================================================================
// Canvas position:fixed dietro a tutti i contenuti. Strategia performance:
//  – Strato statico (stelle deboli, ~85%): pre-renderizzato UNA volta su
//    canvas offscreen, ridisegnato come immagine ogni frame (cheap blit).
//  – Strato dinamico (stelle luminose ~15% + meteore): aggiornato ogni
//    frame con twinkle/scia.
//  – Throttle a ~30 FPS per scaricare la CPU senza perdere fluidità visiva.
//  – Pausa quando la pagina non è visibile (visibilitychange).
(() => {
  const canvas = document.getElementById('starfield');
  if (!canvas) return;
  const ctx = canvas.getContext('2d', { alpha: true });
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // dpr cap a 1.5 → metà dei pixel rispetto a 2.0 con perdita visiva minima
  let dpr = Math.min(window.devicePixelRatio || 1, 1.5);
  let w = 0, h = 0;

  // strato statico (stelle deboli) pre-renderizzato
  const offscreen = document.createElement('canvas');
  const offCtx = offscreen.getContext('2d');

  // stelle luminose (animate)
  let brightStars = [];

  // stelle cadenti attive
  const meteors = [];
  let nextMeteorAt = 0;

  function rand(a, b){ return a + Math.random() * (b - a); }

  function rebuild(){
    w = window.innerWidth;
    h = window.innerHeight;
    canvas.width  = Math.max(1, Math.floor(w * dpr));
    canvas.height = Math.max(1, Math.floor(h * dpr));
    canvas.style.width  = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    // densità totale: ~1 stella ogni 1100 px²  →  ~840 stelle a 1280×720
    const total = Math.floor((w * h) / 1100);
    const dimCount    = Math.floor(total * 0.85);
    const brightCount = total - dimCount;

    // ---- pre-render strato statico (deboli) ----
    offscreen.width  = canvas.width;
    offscreen.height = canvas.height;
    offCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
    offCtx.clearRect(0, 0, w, h);
    offCtx.globalCompositeOperation = 'lighter';
    for (let i = 0; i < dimCount; i++){
      const x = Math.random() * w;
      const y = Math.random() * h;
      const r = rand(0.3, 0.85);
      const a = rand(0.45, 0.9);
      const gold = Math.random() < 0.18;
      offCtx.fillStyle = gold
        ? `rgba(255, 230, 150, ${a})`
        : `rgba(252, 246, 226, ${a})`;
      offCtx.beginPath();
      offCtx.arc(x, y, r, 0, Math.PI * 2);
      offCtx.fill();
    }
    offCtx.globalCompositeOperation = 'source-over';

    // ---- stelle luminose dinamiche ----
    brightStars = new Array(brightCount);
    for (let i = 0; i < brightCount; i++){
      const huge = Math.random() < 0.12;   // ~1.8% del totale
      brightStars[i] = {
        x: Math.random() * w,
        y: Math.random() * h,
        r: huge ? rand(1.6, 2.6) : rand(0.9, 1.6),
        bright: huge ? 1.0 : rand(0.8, 1.0),
        tw: Math.random() * Math.PI * 2,
        tws: rand(0.5, 2.0),
        gold: Math.random() < 0.22,
        huge,
      };
    }
  }

  // ---- spawn di una stella cadente ----
  function spawnMeteor(now){
    // partenza fuori schermo, dall'alto/sinistra, traiettoria diagonale verso il basso/destra
    const startEdge = Math.random();
    let x, y;
    if (startEdge < 0.5){
      x = rand(-100, w * 0.4);
      y = rand(-80, -10);
    } else {
      x = rand(-100, -20);
      y = rand(0, h * 0.5);
    }
    // angolo: -10° a 35° dall'orizzontale (verso il basso a destra)
    const angle = rand(0.18, 0.78);
    const speed = rand(900, 1500);   // px/s
    const len   = rand(110, 220);
    meteors.push({
      x, y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      len,
      life: 0,
      ttl: rand(0.55, 1.2),
      gold: Math.random() < 0.35,
      born: now,
    });
  }

  // ---- frame loop, throttled ~30 FPS ----
  let lastFrame = 0;
  let raf;
  let pausedByVisibility = false;

  function frame(now){
    raf = requestAnimationFrame(frame);
    if (pausedByVisibility) return;
    if (now - lastFrame < 33) return;        // ~30 fps
    const dt = Math.min((now - lastFrame) / 1000, 0.05);
    lastFrame = now;
    const t = now * 0.001;

    ctx.clearRect(0, 0, w, h);

    // strato statico (blit cheap)
    ctx.drawImage(offscreen, 0, 0, w, h);

    // strato dinamico — additive
    ctx.globalCompositeOperation = 'lighter';

    // 1) stelle luminose con twinkle + glow
    for (let i = 0, n = brightStars.length; i < n; i++){
      const s = brightStars[i];
      const tw = reduceMotion ? 1.0 : (0.6 + 0.4 * Math.sin(s.tw + t * s.tws));
      const a = s.bright * tw;

      // glow halo (solo per huge → costo contenuto)
      if (s.huge){
        const radius = s.r * 7;
        const grad = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, radius);
        if (s.gold){
          grad.addColorStop(0,    `rgba(255, 224, 122, ${0.6 * a})`);
          grad.addColorStop(0.35, `rgba(245, 205, 71,  ${0.20 * a})`);
        } else {
          grad.addColorStop(0,    `rgba(247, 238, 213, ${0.6 * a})`);
          grad.addColorStop(0.35, `rgba(237, 224, 184, ${0.18 * a})`);
        }
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(s.x - radius, s.y - radius, radius*2, radius*2);

        // crocetta van gogh
        const len = s.r * 6 * (0.7 + 0.3*tw);
        ctx.strokeStyle = s.gold
          ? `rgba(255, 224, 122, ${0.5 * a})`
          : `rgba(247, 238, 213, ${0.45 * a})`;
        ctx.lineWidth = 0.7;
        ctx.beginPath();
        ctx.moveTo(s.x - len, s.y); ctx.lineTo(s.x + len, s.y);
        ctx.moveTo(s.x, s.y - len); ctx.lineTo(s.x, s.y + len);
        ctx.stroke();
      }

      // core
      ctx.fillStyle = s.gold
        ? `rgba(255, 230, 150, ${a})`
        : `rgba(252, 246, 226, ${a})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    }

    // 2) stelle cadenti — spawn molto frequente per la richiesta "molte di più"
    if (!reduceMotion){
      if (t > nextMeteorAt){
        // 1–3 meteore burst per spawn
        const burst = 1 + (Math.random() < 0.45 ? 1 : 0) + (Math.random() < 0.18 ? 1 : 0);
        for (let i = 0; i < burst; i++) spawnMeteor(t);
        // intervallo medio: 0.6–1.6 s → quasi sempre ce n'è almeno una in volo
        nextMeteorAt = t + rand(0.6, 1.6);
      }

      for (let i = meteors.length - 1; i >= 0; i--){
        const m = meteors[i];
        m.life += dt;
        m.x += m.vx * dt;
        m.y += m.vy * dt;

        // fade in/out (envelope)
        const k = m.life / m.ttl;
        const env = k < 0.15 ? (k / 0.15)
                  : k > 0.75 ? (1 - (k - 0.75) / 0.25)
                             : 1;

        // scia (gradient lineare dietro la testa)
        const norm = Math.hypot(m.vx, m.vy) || 1;
        const ux = m.vx / norm, uy = m.vy / norm;
        const tailX = m.x - ux * m.len;
        const tailY = m.y - uy * m.len;
        const grad = ctx.createLinearGradient(m.x, m.y, tailX, tailY);
        const headColor = m.gold
          ? `rgba(255, 230, 150, ${0.95 * env})`
          : `rgba(252, 246, 226, ${0.95 * env})`;
        const midColor  = m.gold
          ? `rgba(255, 200, 100, ${0.45 * env})`
          : `rgba(220, 220, 240, ${0.45 * env})`;
        grad.addColorStop(0,    headColor);
        grad.addColorStop(0.35, midColor);
        grad.addColorStop(1,    'rgba(0,0,0,0)');
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.6;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(tailX, tailY);
        ctx.lineTo(m.x, m.y);
        ctx.stroke();

        // testa luminosa
        const headRad = 6 * env;
        if (headRad > 0.3){
          const hg = ctx.createRadialGradient(m.x, m.y, 0, m.x, m.y, headRad);
          hg.addColorStop(0, headColor);
          hg.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = hg;
          ctx.fillRect(m.x - headRad, m.y - headRad, headRad*2, headRad*2);
        }

        // rimuovi se finita o troppo lontana
        if (m.life > m.ttl || m.x > w + 200 || m.y > h + 200){
          meteors.splice(i, 1);
        }
      }
    }

    ctx.globalCompositeOperation = 'source-over';
  }

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      rebuild();
    }, 150);
  });

  // pausa quando il tab non è visibile
  document.addEventListener('visibilitychange', () => {
    pausedByVisibility = document.hidden;
    lastFrame = performance.now();   // evita salti di dt al rientro
  });

  rebuild();
  if (reduceMotion){
    // un frame solo: drawImage + stelle luminose statiche, niente meteore
    ctx.drawImage(offscreen, 0, 0, w, h);
    ctx.globalCompositeOperation = 'lighter';
    for (const s of brightStars){
      ctx.fillStyle = s.gold
        ? `rgba(255, 230, 150, ${s.bright})`
        : `rgba(252, 246, 226, ${s.bright})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalCompositeOperation = 'source-over';
  } else {
    raf = requestAnimationFrame(frame);
  }
})();
</script>

</body>
</html>
